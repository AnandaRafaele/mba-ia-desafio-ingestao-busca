GOOGLE_API_KEY=
GOOGLE_EMBEDDING_MODEL=models/embedding-001
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Compatível com o docker-compose.yml deste repositório
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/rag
# Nome da coleção (tabela) usada pelo PGVector para armazenar os chunks/embeddings
PG_VECTOR_COLLECTION_NAME=gpt5_collection
# Caminho do PDF a ser ingerido (relativo ao root do projeto)
PDF_PATH=./document.pdf
MODEL_NAME=gemini-2.5-flash-lite